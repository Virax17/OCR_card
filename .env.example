GEMINI_API_KEY=replace_with_google_ai_studio_api_key
GEMINI_API_KEY_2=optional_second_google_ai_studio_api_key
GEMINI_API_KEY_3=optional_third_google_ai_studio_api_key
GEMINI_API_KEY_4=optional_fourth_google_ai_studio_api_key
GEMINI_API_KEY_5=optional_fifth_google_ai_studio_api_key
GEMINI_API_KEY_6=optional_sixth_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PROJECT_COUNT=6
GEMINI_DAILY_REQUEST_LIMIT_PER_PROJECT=20
GEMINI_MINUTE_REQUEST_LIMIT_PER_PROJECT=5
GEMINI_DAILY_TOKEN_LIMIT_PER_PROJECT=250000
# Google Vision credentials — pick ONE of the two below:
# (A) Local dev: path to a service-account JSON file on disk.
GOOGLE_APPLICATION_CREDENTIALS=D:\path\to\service-account.json
# (B) Cloud/no-file (e.g. Render): the FULL service-account JSON as one line
#     (raw JSON or base64-encoded). Leave GOOGLE_APPLICATION_CREDENTIALS unset
#     when you use this. Do NOT commit the real value.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...", ...}

# Ephemeral scratch dir for per-event data (SQLite + images + exports).
# On cloud hosts point this at a writable temp dir, e.g. /tmp/events.
# EVENTS_ROOT=events
GOOGLE_VISION_MODEL=builtin/weekly
GOOGLE_VISION_TIMEOUT_SECONDS=60
GOOGLE_VISION_MINUTE_REQUEST_LIMIT=1800
GOOGLE_VISION_FREE_UNITS_MONTHLY=1000
GOOGLE_VISION_PRICE_PER_1000=1.50

# MongoDB — persistent usage credit limits that survive restarts and auto-reset
# by time bucket (calendar month for Vision, calendar day for Gemini).
# Provide the FULL SRV connection string. Do NOT commit the real value.
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=cardscan
MONGO_USAGE_ENABLED=true
# Enforced hard caps (block new scans when reached):
MONGO_VISION_MONTHLY_LIMIT=1000
MONGO_GEMINI_DAILY_LIMIT=120
# Days a usage bucket lives before MongoDB auto-deletes it (TTL).
MONGO_USAGE_TTL_DAYS=40
